---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Andrea Ophelia - Multimediedesigner">
  <article class="space-y-24">
    <!-- HERO SECTION -->
    <section class="relative overflow-hidden py-24">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="grid items-center gap-12 lg:grid-cols-[1.2fr_0.8fr]">
          <div class="space-y-8">
            <p class="text-sm uppercase tracking-[0.35em] text-zinc-500">
              Multimedie Designer/ Digital konceptudvikler
            </p>
            <h1
              class="font-serif text-5xl md:text-6xl lg:text-7xl text-zinc-900 leading-tight"
            >
              Andrea Ophelia <br /> Normand Toth
            </h1>
            <p class="max-w-2xl text-xl text-zinc-600 leading-9">
              Jeg skaber engagerende digitale oplevelser med UX/UI, visuel
              storytelling og konceptudvikling, der kombinerer kreativitet og
              funktionalitet.
            </p>
            <div class="flex flex-wrap gap-4">
              <a
                href="/#projects"
                class="inline-flex items-center justify-center rounded-full bg-zinc-900 px-8 py-3 text-white font-semibold hover:bg-zinc-800 transition"
              >
                Se projekter
              </a>
              <a
                href="/#contact"
                class="inline-flex items-center justify-center rounded-full border border-zinc-300 px-8 py-3 text-zinc-900 hover:border-zinc-800 transition"
              >
                Kontakt mig
              </a>
            </div>
          </div>
          <div class="rounded-[2rem] bg-zinc-100 p-6 shadow-xl">
            <img
              class="w-full rounded-[1.5rem] object-cover"
              src="../img/mig.png"
              alt="Andrea Ophelia"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- PROJECTS SECTION -->
    <section id="projects" class="py-24 bg-zinc-50">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div
          class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between mb-10"
        >
          <h2 class="font-serif text-4xl md:text-5xl text-zinc-900">
            Mine projekter
          </h2>
          <p class="max-w-2xl text-zinc-600 leading-7">Udvalgte cases</p>
        </div>

        <div class="grid gap-6 grid-cols-1 md:grid-cols-3">
          <a
            href="/projekt1"
            class="group block rounded-[1.75rem] border border-zinc-200 bg-white overflow-hidden shadow-sm transition hover:-translate-y-1 hover:shadow-lg"
          >
            <div class="h-56 overflow-hidden bg-zinc-100">
              <img
                src="../img/karrusel.png"
                alt="Karrusel Festival"
                class="w-full h-full object-cover group-hover:scale-105 transition"
              />
            </div>
            <div class="p-6">
              <span
                class="inline-flex rounded-full bg-zinc-900 px-3 py-1 text-xs uppercase tracking-[0.25em] text-white"
                >Case 01</span
              >
              <h3 class="mt-4 text-2xl font-semibold text-zinc-900">
                Karrusel Festival
              </h3>
              <p class="mt-3 text-zinc-600 leading-7">
                En levende festivaloplevelse, hvor visuel identitet og
                brugervenlig navigation mødes.
              </p>
            </div>
          </a>

          <a
            href="/projekt2"
            class="group block rounded-[1.75rem] border border-zinc-200 bg-white overflow-hidden shadow-sm transition hover:-translate-y-1 hover:shadow-lg"
          >
            <div class="h-56 overflow-hidden bg-zinc-100">
              <img
                src="/img/Smykke.png"
                alt="Digital wearable"
                class="w-full h-full object-cover group-hover:scale-105 transition"
              />
            </div>
            <div class="p-6">
              <span
                class="inline-flex rounded-full bg-zinc-900 px-3 py-1 text-xs uppercase tracking-[0.25em] text-white"
                >Case 02</span
              >
              <h3 class="mt-4 text-2xl font-semibold text-zinc-900">
                Digital wearable
              </h3>
              <p class="mt-3 text-zinc-600 leading-7">
                En digital case med fokus på mennesker, indhold og moderne
                kommunikation.
              </p>
            </div>
          </a>

          <a
            href="/projekt3"
            class="group block rounded-[1.75rem] border border-zinc-200 bg-white overflow-hidden shadow-sm transition hover:-translate-y-1 hover:shadow-lg"
          >
            <div class="h-56 overflow-hidden bg-zinc-100">
              <img
                src="../img/rigshospitalet.png"
                alt="Visuel kommunikation"
                class="w-full h-full object-cover group-hover:scale-105 transition"
              />
            </div>
            <div class="p-6">
              <span
                class="inline-flex rounded-full bg-zinc-900 px-3 py-1 text-xs uppercase tracking-[0.25em] text-white"
                >Case 03</span
              >
              <h3 class="mt-4 text-2xl font-semibold text-zinc-900">
                Rigshospitalet
              </h3>
              <p class="mt-3 text-zinc-600 leading-7">
                Et digitalt koncept til rigshospitalet med fokus på strategisk
                design og brugervenlighed
              </p>
            </div>
          </a>

          <a
            href="/projekt4"
            class="group block rounded-[1.75rem] border border-zinc-200 bg-white overflow-hidden shadow-sm transition hover:-translate-y-1 hover:shadow-lg"
          >
            <div class="h-56 overflow-hidden bg-zinc-100">
              <img
                src="../img/savetheturtles.png"
                alt="Projekt 4"
                class="w-full h-full object-cover group-hover:scale-105 transition"
              />
            </div>
            <div class="p-6">
              <span
                class="inline-flex rounded-full bg-zinc-900 px-3 py-1 text-xs uppercase tracking-[0.25em] text-white"
                >Case 04</span
              >
              <h3 class="mt-4 text-2xl font-semibold text-zinc-900">
                Save the Turtles
              </h3>
              <p class="mt-3 text-zinc-600 leading-7">
                One page projekt for save the turtles, med fokus på visuel
                kommunikation og scrollytelling.
              </p>
            </div>
          </a>

          <a
            href="/projekt5"
            class="group block rounded-[1.75rem] border border-zinc-200 bg-white overflow-hidden shadow-sm transition hover:-translate-y-1 hover:shadow-lg"
          >
            <div class="h-56 overflow-hidden bg-zinc-100">
              <img
                src="../img/doxa1.png"
                alt="DoxaFlowers"
                class="w-full h-full object-cover group-hover:scale-105 transition"
              />
            </div>
            <div class="p-6">
              <span
                class="inline-flex rounded-full bg-zinc-900 px-3 py-1 text-xs uppercase tracking-[0.25em] text-white"
                >Case 05</span
              >
              <h3 class="mt-4 text-2xl font-semibold text-zinc-900">
                Doxaflowers
              </h3>
              <p class="mt-3 text-zinc-600 leading-7">
                Et projekt for Doxa flowers med fokus på visuel identitet og
                moderne webdesign.
              </p>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- PROFILE SECTION -->
    <section id="profile" class="py-24">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="grid items-center gap-12 lg:grid-cols-[0.95fr_1.05fr]">
          <div>
            <img
              class="w-full rounded-[1.5rem] object-cover"
              id="parallax-text"
              src="../img/cloud.png"
              alt="design work"
            />
          </div>
          <div class="space-y-6">
            <h2 class="font-serif text-4xl md:text-5xl text-zinc-900">
              Om mig
            </h2>

            <p class="text-lg text-zinc-700 leading-9">
              Mit Navn er Andrea Toth, 26 år gammel og fra Købehavn. <br />Jeg
              arbejder med digital konceptudvikling, hvor brugerbehov, og visuel
              identitet bliver samlet i gennemtænkte digitale løsninger. Gennem
              research, idéudvikling og prototyping skaber jeg oplevelser, der
              både fungerer praktisk og visuelt.
            </p>

            <p class="text-lg text-zinc-700 leading-9">
              Mit arbejde tager udgangspunkt i designprocesser som Double
              Diamond, hvor jeg arbejder analytisk med indsigt, brugerrejser og
              iterationer for at udvikle løsninger.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CONTACT SECTION -->
    <section id="contact" class="py-24 bg-zinc-100">
      <div class="max-w-5xl mx-auto px-6 lg:px-8">
        <div class="rounded-[2rem] bg-white p-10 shadow-lg">
          <div class="grid gap-10 lg:grid-cols-[1fr_0.8fr] lg:items-center">
            <div>
              <h2 class="font-serif text-4xl md:text-5xl text-zinc-900 mb-4">
                Lad os arbejde sammen
              </h2>
              <p class="text-lg text-zinc-700 leading-8">
                Jeg er altid interesseret i nye projekter og samarbejder inden
                for digitalt design, konceptudvikling og visuel kommunikation.
              </p>
            </div>
            <div class="space-y-4 text-zinc-700">
              <p>
                <span class="font-semibold text-zinc-900">E-mail:</span>
                <a
                  href="mailto:andreaont@email.com"
                  class="text-zinc-900 hover:underline">andreaont@email.com</a
                >
              </p>
              <p>
                <span class="font-semibold text-zinc-900">Telefon:</span>
                <a href="tel:+45123456789" class="text-zinc-900 hover:underline"
                  >+45 23740105</a
                >
              </p>
              <p>
                <span class="font-semibold text-zinc-900">LinkedIn:</span>
                <a
                  href="https://www.linkedin.com/in/andrea-toth-02b6802b5/"
                  target="_blank"
                  class="text-zinc-900 hover:underline"
                  >linkedin.com/in/andreaphelia</a
                >
              </p>
            </div>
          </div>
          <div class="mt-10 text-center">
            <a
              href="mailto:andreaont@email.com"
              class="inline-flex items-center justify-center rounded-full bg-zinc-900 px-10 py-4 text-sm font-semibold uppercase tracking-[0.18em] text-white transition hover:bg-zinc-800"
            >
              Kontakt mig
            </a>
          </div>
        </div>
      </div>
    </section>
  </article>
</MainLayout>

<script>
  //@ts-nocheck
  document.addEventListener("scroll", function () {
    const scrollPosition = window.scrollY;
    const element = document.getElementById("parallax-text");
    if (element) {
      element.style.transform = `translateX(${scrollPosition * 0.05}px)`;
    }
  });
</script>
