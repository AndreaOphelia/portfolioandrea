---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Karrusel Festival - Andrea Ophelia">
  <article>
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6 lg:px-8 space-y-12">
        <div class="space-y-4">
          <p class="text-sm uppercase tracking-[0.35em] text-zinc-500">
            Case 01
          </p>
          <h1 class="font-serif text-5xl md:text-6xl text-zinc-900">
            Karrusel Festival
          </h1>
          <p class="max-w-3xl text-xl text-zinc-600 leading-9">
            En festivalcase med fokus på visuel energi, brugervenlig navigation
            og stærk storytelling.
          </p>
        </div>

        <div class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr]">
          <div class="rounded-[2rem] bg-zinc-50 p-8 shadow-sm">
            <h2 class="text-2xl font-semibold text-zinc-900 mb-4">
              Projekt detaljer
            </h2>
            <ul class="space-y-3 text-zinc-700">
              <li><strong>Case:</strong> Karrusel Festival</li>
              <li><strong>År:</strong> 2024</li>
              <li><strong>Teknologier:</strong> Astro, Tailwind CSS</li>
              <li><strong>Varighed:</strong> 1 måned</li>
            </ul>
          </div>
          <div class="rounded-[2rem] bg-zinc-50 p-8 shadow-sm">
            <h2 class="text-2xl font-semibold text-zinc-900 mb-4">Metoder</h2>
            <ul class="space-y-3 text-zinc-700">
              <li>
                • Projektet er udviklet med udgangspunkt i Double
                Diamond-modellen for at sikre en struktureret og brugercentreret
                proces
              </li>
              <li>
                • Design og wireframes er udarbejdet i Figma med fokus på visuel
                identitet, prototyping og brugeroplevelse
              </li>
              <li>
                • Frontenden er bygget i Astro og Tailwind CSS for at skabe en
                moderne, hurtig og responsiv løsning
              </li>
              <li>
                • Der er arbejdet med iterationer og løbende test for at
                optimere både design og funktionalitet
              </li>
              <li>
                • Fokus på samspillet mellem typografi, billeder og layout for
                at skabe en stærk visuel helhed
              </li>
            </ul>
          </div>
        </div>

        <div class="py-8">
          <div class="mx-auto max-w-4xl">
            <img
              class="w-full rounded-[2rem] object-cover shadow-lg"
              src="/img/karrusel.png"
              alt="Karrusel Festival"
            />
          </div>
          <div class="mx-auto max-w-4xl mt-12">
            <div class="grid gap-8 md:grid-cols-2">
              <img
                class="w-full rounded-[1.75rem] object-cover shadow-md"
                src="/img/karruselliste.png"
                alt="Karrusel festival detalje"
              />
              <img
                class="w-full rounded-[1.75rem] object-cover shadow-md"
                src="/img/Single.png"
                alt="Karrusel projekt detalje"
              />
            </div>
          </div>
        </div>

        <div class="text-center">
          <a
            href="/"
            class="inline-flex items-center justify-center rounded-full bg-zinc-900 px-10 py-4 text-sm font-semibold uppercase tracking-[0.18em] text-white transition hover:bg-zinc-800"
          >
            Tilbage til portfolio
          </a>
        </div>
      </div>
    </section>
  </article>
</MainLayout>
