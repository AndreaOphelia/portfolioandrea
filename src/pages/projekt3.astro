---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Visuel kommunikation - Andrea Ophelia">
  <article>
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6 lg:px-8 space-y-12">
        <div class="space-y-4">
          <p class="text-sm uppercase tracking-[0.35em] text-zinc-500">
            Case 03
          </p>
          <h1 class="font-serif text-5xl md:text-6xl text-zinc-900">
            Rigshospitalet
          </h1>
          <p class="max-w-3xl text-xl text-zinc-600 leading-9">
            Et digitalt koncept til rigshospitalet med fokus på strategisk
            design og brugervenlighed
          </p>
        </div>

        <div class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr]">
          <div class="rounded-[2rem] bg-zinc-50 p-8 shadow-sm">
            <h2 class="text-2xl font-semibold text-zinc-900 mb-4">
              Projekt detaljer
            </h2>
            <ul class="space-y-3 text-zinc-700">
              <li><strong>Case:</strong> Rigshospitalet</li>
              <li><strong>År:</strong> 2026</li>
              <li><strong>Teknologier:</strong> Figma, Figma AI</li>
              <li><strong>Varighed:</strong> 2 uger</li>
            </ul>
          </div>
          <div class="rounded-[2rem] bg-zinc-50 p-8 shadow-sm">
            <h2 class="text-2xl font-semibold text-zinc-900 mb-4">Metoder</h2>
            <ul class="space-y-3 text-zinc-700">
              <li>
                • Udviklet en vidensdelingsportal til Rigshospitalet med fokus
                på brugervenlighed og effektiv adgang til information
              </li>
              <li>
                • Designprocessen tog udgangspunkt i brugerbehov, arbejdsgange
                og reduktion af tidsforbrug i hverdagen
              </li>
              <li>
                • Struktur og navigation er udviklet med fokus på intuitiv
                brugeroplevelse og hurtig informationssøgning
              </li>
              <li>
                • Arbejdet med UX-metoder, wireframes og prototyper for at teste
                og forbedre løsningen løbende
              </li>
              <li>
                • Visuelt design skabt med fokus på overskuelighed,
                tilgængelighed og et roligt digitalt udtryk
              </li>
            </ul>
          </div>
        </div>

        <div class="py-8">
          <div class="mx-auto max-w-4xl">
            <img
              class="w-full rounded-[2rem] object-cover shadow-lg"
              src="../img/rigshospitalet.png"
              alt="Projekt 3 hovedbillede"
            />
          </div>
          <div class="mx-auto max-w-4xl mt-12">
            <div class="grid gap-8 md:grid-cols-2">
              <img
                class="w-full rounded-[1.75rem] object-cover shadow-md"
                src="../img/rigshospitaletstep1.png"
                alt="Projekt 3 detalje 1"
              />
              <img
                class="w-full rounded-[1.75rem] object-cover shadow-md"
                src="../img/step3.png"
                alt="Projekt 3 detalje 2"
              />
            </div>
          </div>
        </div>

        <div class="text-center">
          <a
            href="/"
            class="inline-flex items-center justify-center rounded-full bg-zinc-900 px-10 py-4 text-sm font-semibold uppercase tracking-[0.18em] text-white transition hover:bg-zinc-800"
          >
            Tilbage til portfolio
          </a>
        </div>
      </div>
    </section>
  </article>
</MainLayout>
