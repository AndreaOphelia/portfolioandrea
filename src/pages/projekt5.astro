---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Projekt 5 - Andrea Ophelia">
  <article>
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6 lg:px-8 space-y-12">
        <div class="space-y-4">
          <p class="text-sm uppercase tracking-[0.35em] text-zinc-500">
            Case 05
          </p>
          <h1 class="font-serif text-5xl md:text-6xl text-zinc-900">
            DoxaFlowers
          </h1>
          <p class="max-w-3xl text-xl text-zinc-600 leading-9">
            Et projekt for Doxa flowers med fokus på visuel identitet og moderne
            webdesign.
          </p>
        </div>

        <div class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr]">
          <div class="rounded-[2rem] bg-zinc-50 p-8 shadow-sm">
            <h2 class="text-2xl font-semibold text-zinc-900 mb-4">
              Projekt detaljer
            </h2>
            <ul class="space-y-3 text-zinc-700">
              <li><strong>Case:</strong> DoxaFlowers</li>
              <li><strong>År:</strong> 2026</li>
              <li><strong>Teknologier:</strong> Figma, Astro, Tailwind CSS</li>
              <li><strong>Varighed:</strong> 2 måneder</li>
              <li>
                <a
                  href="https://doxaflowers.netlify.app/"
                  target="_blank"
                  class="font-semibold text-zinc-900 hover:underline"
                >
                  Se projekt på Netlify
                </a>
              </li>
            </ul>
          </div>
          <div class="rounded-[2rem] bg-zinc-50 p-8 shadow-sm">
            <h2 class="text-2xl font-semibold text-zinc-900 mb-4">
              Metoder & Tilgang
            </h2>

            <ul class="space-y-3 text-zinc-700">
              <li>• Brugercentreret design med fokus på intuitiv navigation</li>
              <li>
                • Kundeorienteret tilgang til visuel identitet og oplevelse
              </li>
              <li>
                • Moderne UI-principper for et klart og engagerende udtryk
              </li>
            </ul>
          </div>
        </div>

        <div class="py-8">
          <div class="mx-auto max-w-4xl">
            <img
              class="w-full rounded-[2rem] object-cover shadow-lg"
              src="../img/doxa1.png"
              alt="DoxaFlowers projekt"
            />
          </div>
          <div class="mx-auto max-w-4xl mt-12">
            <div class="grid gap-8 md:grid-cols-2">
              <img
                class="w-full rounded-[1.75rem] object-cover shadow-md"
                src="../img/doxa2.png"
                alt="DoxaFlowers detalje 1"
              />
              <img
                class="w-full rounded-[1.75rem] object-cover shadow-md"
                src="../img/doxa3.png"
                alt="DoxaFlowers detalje 2"
              />
            </div>
          </div>
        </div>

        <div class="text-center">
          <a
            href="/"
            class="inline-flex items-center justify-center rounded-full bg-zinc-900 px-10 py-4 text-sm font-semibold uppercase tracking-[0.18em] text-white transition hover:bg-zinc-800"
          >
            Tilbage til portfolio
          </a>
        </div>
      </div>
    </section>
  </article>
</MainLayout>
